      "id": 8,
      "title": "EVM Blockchain & Wallet Daemon Simulator Logs (시뮬레이터/온체인 입출금 실시간 스트리밍)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "editorMode": "code",
          "expr": "{container=\"admin-api\"} |= \"WalletDaemonService\" or |= \"블록체인 시뮬레이터\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "showCommonLabels": false,
        "prettifyLogMessage": false
      }
    }
