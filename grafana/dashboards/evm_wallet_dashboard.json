        "x": 0,
        "y": 4
      },
      "id": 5,
      "title": "Total User Deposited Assets (사용자 지갑 총 잔고 현황)",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT currency, SUM(balance) AS \"Available Balance\", SUM(locked_balance) AS \"Locked Balance\", COUNT(user_id) AS \"Total Wallets\" FROM wallets GROUP BY currency ORDER BY currency;",
          "refId": "A",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "title": "Crypto Withdrawals Status Summary (출금 신청 처리 현황)",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT status, COUNT(*) AS \"Count\", SUM(amount) AS \"Total Amount\" FROM crypto_withdrawals GROUP BY status ORDER BY status;",
          "refId": "A",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "title": "EVM RPC Request Frequency (Ganache Container) (초당 EVM RPC 호출 빈도)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({container=\"ganache\"}[$__interval]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "light-blue"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
