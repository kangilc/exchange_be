<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console Appender 정의 (JSON 포맷 출력) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
    </appender>

    <!-- Async Appender 정의 (Console I/O 비동기 격리로 지연 방지) -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="STDOUT" />
        <!-- 큐에 대기 중인 이벤트가 지연 시간을 유발하지 않도록 설정 -->
        <queueSize>1024</queueSize>
        <!-- 큐가 가득 찼을 때 로그 유실을 방지하기 위해 버리지 않음 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 버퍼 공간이 부족할 때 호출 스레드를 블로킹할지 여부 (false 설정 시 비동기 큐 초과할 때 버림 없이 블로킹하여 안전 보장) -->
        <neverBlock>false</neverBlock>
    </appender>

    <!-- 환경변수 LOG_LEVEL 값을 읽어서 적용 (기본값: INFO) -->
    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="ASYNC" />
    </root>

</configuration>
