# ==========================================
# DEV PROFILE - Docker Container bridge network
# ==========================================
SYMBOL=BTC-USD
KAFKA_BROKER=kafka:9092
ENGINE_HOST=engine-btc
ENGINE_PORT=9998
COMMAND_PORT=9999
PORT=8088
LOG_LEVEL=INFO
TELEMETRY_ENABLED=true
ADA_COMMAND_PORT=9997
ADA_ENGINE_PORT=9996
ADA_ENGINE_HOST=engine-ada
METRICS_ENABLED=true
MAX_ORDERS=10000000

# JAF Token / EVM RPC
EVM_RPC_URL=http://localhost:8545
EVM_RPC_URL_DOCKER=http://ganache:8545
EVM_PRIVATE_KEY=0x4f3edf983ac636a65a842ce7c78d9aa706d3b113bce9c46f30d7d21715b23b1d

# JWT Authentication Secret Key (min 32 chars)
JWT_SECRET=super_secure_jwt_secret_key_at_least_32_chars_long_exchange_api_token

# Socket Connect/Read Timeout & Reconnect settings for Matching Engine
ENGINE_CONNECT_TIMEOUT_MS=5000
ENGINE_READ_TIMEOUT_MS=60000
MAX_BACKOFF_MS=30000



# 주문 생성기 속도 조절 (ms 단위, 작을수록 빠름)
GENERATOR_SLEEP_MIN=50
GENERATOR_SLEEP_MAX=250
